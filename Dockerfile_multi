FROM --platform=$BUILDPLATFORM golang:1.21 AS build
WORKDIR /app
COPY . .
ARG TARGETOS TARGETARCH
RUN GOOS=$TARGETOS GOARCH=$TARGETARCH go build -o myapp

# second stage copy from the first stage with alias build
FROM alpine
COPY --from=build /app/myapp /myapp


# to build the image run with buildx and pass the platform argument 
docker buildx build --platform linux/amd64,linux/arm64 -t multi-platform-app .
